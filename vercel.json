{
    "version": 2,
    "rewrites": [
        { "source": "/pricing", "destination": "/pricing.html" },
        { "source": "/checkout", "destination": "/checkout.html" },
        { "source": "/docs", "destination": "/docs.html" },
        { "source": "/api/(.*)", "destination": "/api/$1" },
        { "source": "/(.*)", "destination": "/$1" }
    ]
}
